# Workbook and runtime
WORKBOOK_PATH=Final_Global_Software_Companies_Job_Portals.xlsx
CONCURRENCY=4
PER_DOMAIN_CONCURRENCY=2
BROWSER_CONCURRENCY=1
DETAIL_CONCURRENCY=4
REQUEST_TIMEOUT_MS=20000
BROWSER_TIMEOUT_MS=25000
REQUEST_RETRIES=2
RETRY_BASE_MS=400
RETRY_MAX_MS=5000
MAX_PAGES_PER_PORTAL=5
MAX_GENERIC_PAGES=3
MAX_JOBS_PER_PORTAL=150
MAX_DETAIL_JOBS_PER_PORTAL=80
MAX_COMPANIES=0

# GitHub Actions provides these automatically. Set them only for local integration testing.
GITHUB_TOKEN=
GITHUB_REPOSITORY=
GITHUB_API_URL=https://api.github.com

# Optional SMTP email. GitHub Issues are the default cloud notification channel.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_TO=
